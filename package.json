{
  "name": "gutu-lib-admin-contracts",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/libraries/admin-contracts build",
    "typecheck": "bun run --cwd framework/libraries/admin-contracts typecheck",
